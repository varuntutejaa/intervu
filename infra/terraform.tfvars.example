# Copy to terraform.tfvars and fill in — never commit the real file
# (already gitignored).

aws_region             = "us-east-1"
ec2_key_pair_name      = "your-ec2-key-pair"
ssh_allowed_cidr        = "203.0.113.4/32" # your IP, not 0.0.0.0/0
cognito_user_pool_arn   = "arn:aws:cognito-idp:us-east-1:123456789012:userpool/us-east-1_xxxxxxxxx"
domain_name             = ""

# Also required — pass via TF_VAR_db_password instead of committing it here:
#   export TF_VAR_db_password="..."
