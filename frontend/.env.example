# Copy this file to .env and fill in your Firebase project's web app config.
# Firebase Console → Project Settings → General → Your apps → Web app.
# These values aren't secret (they're meant to ship in the client bundle),
# but they're per-project, so they live in env vars rather than hardcoded.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_APP_ID=
