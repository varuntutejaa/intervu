# Copy this file to .env and fill in your actual RDS values.
# Never commit .env — it's already gitignored.

# Option A: single connection string (takes priority if set)
# DATABASE_URL=postgresql://USERNAME:PASSWORD@YOUR-INSTANCE.xxxxxxxxxx.us-east-1.rds.amazonaws.com:5432/intervu

# Option B: discrete fields (used if DATABASE_URL is not set)
PGHOST=your-instance.xxxxxxxxxx.us-east-1.rds.amazonaws.com
PGPORT=5432
PGDATABASE=intervu
PGUSER=your_username
PGPASSWORD=your_password

# RDS requires SSL by default — leave true unless you've disabled it
DB_SSL=true

PORT=3001
CORS_ORIGIN=http://localhost:5174

# Cognito — from your User Pool's "App integration" tab
COGNITO_REGION=us-east-1
COGNITO_CLIENT_ID=your_app_client_id
# Only needed if the App Client has a secret (a "confidential client").
# Never expose this to the frontend — it stays server-side only.
COGNITO_CLIENT_SECRET=your_app_client_secret

# Random string used to sign the session cookie. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Firebase — used only for the Google/GitHub social buttons (Cognito can't
# federate with GitHub natively). From Firebase Console → Project Settings →
# Service Accounts → Generate new private key.
FIREBASE_PROJECT_ID=your-project
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the "private_key" field from the downloaded JSON exactly as-is,
# including the \n escapes and the BEGIN/END PRIVATE KEY lines.
FIREBASE_PRIVATE_KEY=

