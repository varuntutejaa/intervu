# Copy this file to .env and fill in your actual RDS values.
# Never commit .env — it's already gitignored.

# Option A: single connection string (takes priority if set)
# DATABASE_URL=postgresql://USERNAME:PASSWORD@YOUR-INSTANCE.xxxxxxxxxx.us-east-1.rds.amazonaws.com:5432/intervu

# Option B: discrete fields (used if DATABASE_URL is not set)
PGHOST=your-instance.xxxxxxxxxx.us-east-1.rds.amazonaws.com
PGPORT=5432
PGDATABASE=intervu
PGUSER=your_username
PGPASSWORD=your_password

# RDS requires SSL by default — leave true unless you've disabled it
DB_SSL=true

PORT=3001
CORS_ORIGIN=http://localhost:5174
# The publicly-reachable origin the app is served from — same value as
# CORS_ORIGIN in practice, but used separately to build OAuth redirect URIs
# and the post-login redirect target. In dev this is where Vite proxies
# /api to this server; in prod it's your CloudFront domain, not the raw
# EC2 address (Google/GitHub need something they can actually reach).
PUBLIC_URL=http://localhost:5174

# Cognito — from your User Pool's "App integration" tab
COGNITO_REGION=us-east-1
COGNITO_CLIENT_ID=your_app_client_id
# Only needed if the App Client has a secret (a "confidential client").
# Never expose this to the frontend — it stays server-side only.
COGNITO_CLIENT_SECRET=your_app_client_secret

# Random string used to sign the session cookie. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Google/GitHub social login — Cognito remains the system of record for
# email/password; these two go through their own OAuth redirect flow
# instead (Cognito can't federate with GitHub natively).
#
# Google: Google Cloud Console -> APIs & Services -> Credentials -> Create
# OAuth client ID -> Web application. Add both
#   http://localhost:5174/api/auth/google/callback (dev)
#   https://your-cloudfront-domain/api/auth/google/callback (prod)
# as Authorized redirect URIs on the same client.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub: github.com/settings/developers -> New OAuth App. Only one
# callback URL is allowed per app, so most setups need two apps (one per
# environment) — set Authorization callback URL to
#   https://your-cloudfront-domain/api/auth/github/callback (prod)
# and optionally a second app with
#   http://localhost:5174/api/auth/github/callback (dev)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

